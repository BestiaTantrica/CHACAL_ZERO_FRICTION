[Unit]
Description=Freqtrade Bear Specialist
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/chacal
ExecStart=/home/ubuntu/chacal/.venv/bin/freqtrade trade --config /home/ubuntu/chacal/user_data/configs/config.json --strategy ChacalSniper_Bear44 --strategy-path /home/ubuntu/chacal/PROJECT_SNIPER_AWS/user_data/strategies
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
