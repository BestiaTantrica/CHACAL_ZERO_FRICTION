[Unit]
Description=Freqtrade Bull Specialist
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/chacal
ExecStart=/home/ubuntu/chacal/.venv/bin/freqtrade trade --config /home/ubuntu/chacal/user_data/configs/config.json --strategy ChacalVolumeHunter_V1 --strategy-path /home/ubuntu/chacal/strategies
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
